        <ul class="c-article-subject-list">
            <li class="c-article-subject-list__subject"><a href="/subjects/cheminformatics" data-track="click" data-track-action="view subject" data-track-label="link">Cheminformatics</a></li><li class="c-article-subject-list__subject"><a href="/subjects/virtual-screening" data-track="click" data-track-action="view subject" data-track-label="link">Virtual screening</a></li>
